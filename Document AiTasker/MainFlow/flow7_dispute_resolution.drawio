        <mxCell id="A1" value="A1. Client/Expert chọn&lt;br&gt;&quot;Open Dispute&quot; trong&lt;br&gt;project / milestone" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="30" y="205" width="230" height="72" as="geometry"/></mxCell>
