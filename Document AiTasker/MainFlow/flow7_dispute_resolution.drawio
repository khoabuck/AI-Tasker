        <mxCell id="A12" value="A12. Cập nhật project /&lt;br&gt;milestone theo quyết&lt;br&gt;định của Admin" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="300" y="860" width="230" height="72" as="geometry"/></mxCell>
