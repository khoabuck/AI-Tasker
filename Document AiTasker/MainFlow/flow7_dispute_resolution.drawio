        <mxCell id="A4a" value="A4a. Yêu cầu bổ sung&lt;br&gt;thông tin / bằng chứng" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="575" y="426" width="220" height="68" as="geometry"/></mxCell>
        <mxCell id="A5" value="A5. Tạo dispute với&lt;br&gt;status = OPEN" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="310" y="530" width="210" height="50" as="geometry"/></mxCell>
        <mxCell id="A6" value="A6. Cập nhật trạng thái:&lt;br&gt;• Project = DISPUTED&lt;br&gt;• Milestone = DISPUTED&lt;br&gt;• Payment = FROZEN" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="300" y="615" width="230" height="92" as="geometry"/></mxCell>
        <mxCell id="A7" value="A7. Gửi notification&lt;br&gt;cho bên còn lại" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="310" y="745" width="210" height="50" as="geometry"/></mxCell>
