      <mxCell id="B2" value="B2. Gửi feedback yêu cầu chỉnh sửa" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
