      <mxCell id="B4" value="B4. Chọn:&lt;br&gt;• Approve&lt;br&gt;• Open Dispute (nếu hết revision)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
        <mxGeometry x="30" y="1320" width="240" height="72" as="geometry"/>
      </mxCell>
      <mxCell id="n2" value="2. Tạo escrow request và&lt;br&gt;kiểm tra ví của Client" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
        <mxGeometry x="475" y="225" width="290" height="54" as="geometry"/>
      </mxCell>
      <mxCell id="d2A" value="2A. Số dư ví&lt;br&gt;của Client đủ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;align=center;fontSize=11;" vertex="1" parent="1">
        <mxGeometry x="540" y="330" width="160" height="90" as="geometry"/>
      </mxCell>
      <mxCell id="n3A" value="3A. Thông báo số dư không đủ,&lt;br&gt;yêu cầu nạp thêm" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
